{
    "name": "gh-notify",
    "version": "1.0.0",
    "description": "GitHub Notification Agent - learning project for OAuth2 and multi-step agent workflows",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx src/index.ts",
        "auth": "tsx src/auth/index.ts",
        "agent": "tsx src/agent/index.ts",
        "history": "tsx src/history.ts",
        "build": "tsc --project tsconfig.build.json",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "prettier --write 'src/**/*.ts'",
        "format:check": "prettier --check 'src/**/*.ts'"
    },
    "keywords": [
        "github",
        "notifications",
        "agent",
        "oauth2",
        "mastra"
    ],
    "author": "",
    "license": "ISC",
    "directories": {
        "test": "tests"
    },
    "dependencies": {
        "@hono/node-server": "^1.19.9",
        "@mastra/core": "^1.5.0",
        "@mastra/langfuse": "^1.0.3",
        "@mastra/observability": "^1.2.1",
        "dotenv": "^17.2.4",
        "hono": "^4.11.9",
        "pino": "^10.3.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.3.0",
        "eslint": "^10.0.2",
        "eslint-plugin-unused-imports": "^4.4.1",
        "fast-check": "^4.5.3",
        "mastra": "^1.3.2",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.0.18"
    }
}
